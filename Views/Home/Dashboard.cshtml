@{
    ViewData["Title"] = "Chấm Công";
}

@section Scripts {
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
}

<div class="user-content-inner">
    <div class="dashboard-content">
        <div class="location-section" style="margin-bottom: 20px; text-align: center;">
            <label for="schoolSelect" style="font-weight: 600; font-size: 16px;">🏢 Cơ Sở Làm Việc:</label>
            <select id="schoolSelect" class="form-select" style="max-width: 300px; margin: 10px auto; display: block; padding: 10px; border-radius: 8px; border: 1px solid #ccc; font-size: 15px;">
                <option value="">-- Đang tải danh sách cơ sở --</option>
            </select>
        </div>

        <div class="shift-section" style="margin-bottom: 25px; text-align: center;">
            <p style="font-weight: 600; font-size: 16px; margin-bottom: 10px;">🕒 Chọn Ca Làm Việc (Có thể chọn nhiều):</p>
            <div class="shift-grid" style="display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; max-width: 600px; margin: 0 auto;">
                <label class="shift-item" style="background: white; padding: 8px 15px; border-radius: 20px; border: 1px solid #ddd; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: all 0.3s;">
                    <input type="checkbox" name="shift" value="08:00 - 09:15" style="cursor: pointer;">
                    <span>Ca 1: 08:00 - 09:15</span>
                </label>
                <label class="shift-item" style="background: white; padding: 8px 15px; border-radius: 20px; border: 1px solid #ddd; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: all 0.3s;">
                    <input type="checkbox" name="shift" value="09:30 - 10:45" style="cursor: pointer;">
                    <span>Ca 2: 09:30 - 10:45</span>
                </label>
                <label class="shift-item" style="background: white; padding: 8px 15px; border-radius: 20px; border: 1px solid #ddd; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: all 0.3s;">
                    <input type="checkbox" name="shift" value="13:30 - 14:45" style="cursor: pointer;">
                    <span>Ca 3: 13:30 - 14:45</span>
                </label>
                <label class="shift-item" style="background: white; padding: 8px 15px; border-radius: 20px; border: 1px solid #ddd; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: all 0.3s;">
                    <input type="checkbox" name="shift" value="15:00 - 16:15" style="cursor: pointer;">
                    <span>Ca 4: 15:00 - 16:15</span>
                </label>
                <label class="shift-item" style="background: white; padding: 8px 15px; border-radius: 20px; border: 1px solid #ddd; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: all 0.3s;">
                    <input type="checkbox" name="shift" value="16:30 - 18:00" style="cursor: pointer;">
                    <span>Ca 5: 16:30 - 18:00</span>
                </label>
            </div>
        </div>

        <div class="actions-section">
            <div class="action-card">
                <img src="https://cdn-icons-png.flaticon.com/512/3592/3592873.png" alt="Check In" width="64" style="margin-bottom: 15px;">
                <button id="btnCheckIn" class="btn-action btn-checkin" disabled>CHECK IN</button>
                <p>Bắt đầu ca làm việc của bạn</p>
            </div>
            <div class="action-card">
                <img src="https://cdn-icons-png.flaticon.com/512/3592/3592875.png" alt="Check Out" width="64" style="margin-bottom: 15px;">
                <button id="btnCheckOut" class="btn-action btn-checkout" disabled>CHECK OUT</button>
                <p>Kết thúc ca làm việc của bạn</p>
            </div>
        </div>
    </div>
</div>

<!-- Early Checkout Reason Modal -->
<div id="earlyCheckoutModal" class="modal-overlay" style="display: none;">
    <div class="modal-content" style="max-width: 400px; padding: 25px;">
        <h3 style="margin-top: 0;">Lý Do Về Sớm</h3>
        <p style="font-size: 14px; color: #666; margin-bottom: 15px;">Bạn đang thực hiện Check-out trước khi kết thúc ca làm việc. Vui lòng cho biết lý do:</p>
        <textarea id="earlyLeaveReason" class="form-control" rows="4" placeholder="Nhập lý do của bạn tại đây..." style="width: 100%; margin-bottom: 20px; padding: 10px; border-radius: 8px; border: 1px solid #ddd;"></textarea>
        <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button id="btnCancelEarlyCheckout" class="btn-logout" style="background: #6c757d; border: none;">Hủy</button>
            <button id="btnConfirmEarlyCheckout" class="btn-action" style="background: var(--primary-color); padding: 8px 20px; font-size: 15px; width: auto;">Xác Nhận</button>
        </div>
    </div>
</div>

<!-- Toast -->
<div id="toast" class="toast-message"></div>

<!-- Loading -->
<div id="loadingOverlay" class="loading-overlay">
    <div class="spinner"></div>
    <p style="margin-top: 15px; font-weight: bold; color: #333;">Đang xử lý...</p>
</div>
