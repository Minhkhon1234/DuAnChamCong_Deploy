@{
    ViewData["Title"] = "Báo Cáo Tính Lương";
}

@section Scripts {
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
    <script src="~/js/monthly-report.js" asp-append-version="true"></script>
}

<div class="admin-content-inner">
    <div class="monthly-section" style="margin-top: 20px;">
            <div class="section-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                <h3 style="margin: 0; color: #333;">Bộ Lọc Tìm Kiếm</h3>
                <div class="filter-controls" style="display: flex; gap: 10px;">
                    <select id="monthSelect" class="form-select" style="padding: 10px; border-radius: 8px; border: 1px solid #ddd;">
                        <option value="1">Tháng 1</option>
                        <option value="2">Tháng 2</option>
                        <option value="3">Tháng 3</option>
                        <option value="4">Tháng 4</option>
                        <option value="5">Tháng 5</option>
                        <option value="6">Tháng 6</option>
                        <option value="7">Tháng 7</option>
                        <option value="8">Tháng 8</option>
                        <option value="9">Tháng 9</option>
                        <option value="10">Tháng 10</option>
                        <option value="11">Tháng 11</option>
                        <option value="12">Tháng 12</option>
                    </select>
                    <select id="yearSelect" class="form-select" style="padding: 10px; border-radius: 8px; border: 1px solid #ddd;">
                        <!-- Options generated by JS -->
                    </select>
                    <button id="btnFilterMonthly" class="btn-filter" style="padding: 10px 20px; border-radius: 8px; border: none; background: #007bff; color: white; font-weight: bold; cursor: pointer;">Lọc Dữ Liệu</button>
                    <button id="btnExportExcel" class="btn-filter" style="padding: 10px 20px; border-radius: 8px; border: none; background: #28a745; color: white; font-weight: bold; cursor: pointer;">
                        <i class="fas fa-file-excel"></i> Xuất Excel
                    </button>
                </div>
            </div>
            
            <div class="table-responsive" style="background: white; border-radius: 12px; padding: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                <table class="table admin-table">
                    <thead>
                        <tr>
                            <th>Nhân viên</th>
                            <th>Email</th>
                            <th style="text-align: center;">Số ngày công hợp lệ</th>
                            <th style="text-align: center;">Tổng giờ làm</th>
                        </tr>
                    </thead>
                    <tbody id="monthlyTableBody">
                        <!-- Data goes here -->
                    </tbody>
                </table>
            </div>
        </div>

        <div class="monthly-section" style="margin-top: 40px;">
            <div class="section-header" style="background: white; padding: 20px; border-radius: 12px 12px 0 0; border-bottom: 1px solid #eee;">
                <h3 style="margin: 0; color: #333;">Bảng Công Chi Tiết Theo Ngày</h3>
                <p style="margin: 5px 0 0 0; font-size: 13px; color: #666;">(X: Đúng giờ | M: Muộn | !: Sai vị trí | -: Vắng)</p>
            </div>
            <div class="table-responsive" style="background: white; border-radius: 0 0 12px 12px; padding: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); overflow-x: auto;">
                <table class="table admin-table" style="font-size: 12px;">
                    <thead id="gridTableHeader">
                        <!-- Days generated here -->
                    </thead>
                    <tbody id="gridTableBody">
                        <!-- Grid data here -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>


<!-- Toast -->
<div id="toast" class="toast-message"></div>

<!-- Loading -->
<div id="loadingOverlay" class="loading-overlay">
    <div class="spinner"></div>
    <p style="margin-top: 15px; font-weight: bold; color: #333;">Đang tải dữ liệu...</p>
</div>
