@{
    ViewData["Title"] = "Admin Dashboard";
}

@section Scripts {
    <style>
        .admin-content-inner { padding: 20px; }
        .dashboard-title { margin-bottom: 25px; }
        .dashboard-title h3 { font-size: 1.5rem; font-weight: 700; color: #1e293b; margin-bottom: 5px; }
        
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 15px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            border-left: 4px solid;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        
        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }
        
        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            background: #f8fafc;
        }
        
        .stat-details p {
            margin: 0;
            font-size: 0.875rem;
            color: #64748b;
            font-weight: 500;
        }
        
        .stat-details h3 {
            margin: 5px 0 0;
            font-size: 1.5rem;
            font-weight: 700;
            color: #0f172a;
        }
        
        .stat-card.total-users { border-left-color: #3b82f6; }
        .stat-card.active-users { border-left-color: #10b981; }
        .stat-card.inactive-users { border-left-color: #ef4444; }
        .stat-card.total-leaders { border-left-color: #8b5cf6; }
        
        .admin-action-banner {
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            border-radius: 16px;
            padding: 30px;
            color: white;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 30px;
        }
        
        .banner-text h4 { font-size: 1.25rem; font-weight: 600; margin-bottom: 8px; }
        .banner-text p { margin: 0; opacity: 0.9; }
        
        .btn-manage-users {
            background: white;
            color: #2563eb;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            transition: background 0.2s;
        }
        
        .btn-manage-users:hover {
            background: #f8fafc;
            color: #1d4ed8;
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const token = sessionStorage.getItem('token');
            if (!token) {
                window.location.href = '/';
                return;
            }

            try {
                const response = await fetch('/api/user/stats', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (response.ok) {
                    const stats = await response.json();
                    document.getElementById('statTotalUsers').textContent = stats.totalUsers;
                    document.getElementById('statActiveUsers').textContent = stats.activeUsers;
                    document.getElementById('statInactiveUsers').textContent = stats.inactiveUsers;
                    document.getElementById('statTotalLeaders').textContent = stats.totalLeaders;
                }
            } catch (error) {
                console.error("Lỗi khi tải thống kê:", error);
            }
        });
    </script>
}

<div class="admin-content-inner">
    <div class="dashboard-title">
        <h3>Tổng quan Hệ thống Tài khoản</h3>
        <p>Thống kê số lượng người dùng và phân quyền</p>
    </div>

    <div class="stat-grid">
        <div class="stat-card total-users">
            <div class="stat-icon">👥</div>
            <div class="stat-details">
                <p>Tổng Tài Khoản</p>
                <h3 id="statTotalUsers">--</h3>
            </div>
        </div>
        
        <div class="stat-card active-users">
            <div class="stat-icon">✅</div>
            <div class="stat-details">
                <p>Đang Hoạt Động</p>
                <h3 id="statActiveUsers">--</h3>
            </div>
        </div>

        <div class="stat-card inactive-users">
            <div class="stat-icon">🔒</div>
            <div class="stat-details">
                <p>Bị Vô Hiệu Hóa</p>
                <h3 id="statInactiveUsers">--</h3>
            </div>
        </div>

        <div class="stat-card total-leaders">
            <div class="stat-icon">⭐</div>
            <div class="stat-details">
                <p>Tài Khoản Leader</p>
                <h3 id="statTotalLeaders">--</h3>
            </div>
        </div>
    </div>

    <div class="admin-action-banner">
        <div class="banner-text">
            <h4>Quản lý Nhân Sự</h4>
            <p>Thêm mới, chỉnh sửa thông tin, hoặc cấp quyền Leader cho nhân viên.</p>
        </div>
        <a href="/Home/UserManagement" class="btn-manage-users">Vào Quản Lý Ngay ➔</a>
    </div>
</div>
