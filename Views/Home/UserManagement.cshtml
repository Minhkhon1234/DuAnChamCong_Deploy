@{
    ViewData["Title"] = "Quản Lý Nhân Sự";
}

@section Scripts {
    <link rel="stylesheet" href="~/css/user-management.css" asp-append-version="true" />
    <script src="~/js/user-management.js" asp-append-version="true"></script>
}

<div class="admin-content-inner">
    <div class="section-header">
        <h3>Danh Sách Người Dùng</h3>
        <button id="btnOpenAddModal" class="btn-primary">+ Thêm Nhân Viên</button>
    </div>

        <div class="table-responsive">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th style="text-align: center;">Vai trò</th>
                        <th style="text-align: center;">Trạng thái</th>
                        <th style="text-align: center;">Xem chi tiết</th>
                        <th style="text-align: center;">Hành động</th>
                    </tr>
                </thead>
                <tbody id="userTableBody">
                    <!-- Data rendered here -->
                </tbody>
            </table>
        </div>
    </div>


<!-- Modal Thêm/Sửa Người Dùng -->
<div id="userModal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-header">
            <h3 id="modalTitle">Thêm Nhân Viên Mới</h3>
            <span class="close-btn" id="btnCloseModal">&times;</span>
        </div>
        <div class="modal-body">
            <form id="userForm">
                <input type="hidden" id="userId" value="">
                <div class="form-group">
                    <label>Họ và Tên</label>
                    <input type="text" id="fullName" class="form-control" required placeholder="Nhập họ và tên...">
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" id="email" class="form-control" required placeholder="name@domain.com">
                </div>
                <div class="form-group">
                    <label id="passwordLabel">Mật khẩu</label>
                    <input type="password" id="password" class="form-control" placeholder="Nhập mật khẩu...">
                    <small id="passwordHelp" style="display: none; color: #666;">Để trống nếu không muốn đổi mật khẩu.</small>
                </div>
                <div class="form-group">
                    <label>Phân quyền</label>
                    <select id="role" class="form-control" required>
                        <option value="User">Nhân viên (User)</option>
                        <option value="Leader">Nhóm trưởng (Leader)</option>
                        <option value="Admin">Quản trị viên (Admin)</option>
                    </select>
                </div>
                <div class="modal-actions">
                    <button type="button" id="btnCancelModal" class="btn-secondary">Hủy bỏ</button>
                    <button type="submit" id="btnSaveUser" class="btn-primary">Lưu Thay Đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Toast -->
<div id="toast" class="toast-message"></div>

<!-- Loading -->
<div id="loadingOverlay" class="loading-overlay">
    <div class="spinner"></div>
    <p style="margin-top: 15px; font-weight: bold; color: #333;">Đang tải dữ liệu...</p>
</div>
